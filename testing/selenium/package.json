{
  "name": "cardiotwin-selenium-e2e",
  "version": "1.0.0",
  "description": "Selenium E2E Automation Framework for CardioTwin Application",
  "scripts": {
    "test": "mocha --config .mocharc.yml",
    "test:chrome": "cross-env BROWSER=chrome mocha --config .mocharc.yml",
    "test:edge": "cross-env BROWSER=edge mocha --config .mocharc.yml",
    "test:firefox": "cross-env BROWSER=firefox mocha --config .mocharc.yml",
    "test:headed": "cross-env HEADLESS=false mocha --config .mocharc.yml",
    "test:auth": "mocha --config .mocharc.yml tests/auth.test.js",
    "test:navigation": "mocha --config .mocharc.yml tests/navigation.test.js",
    "test:dashboard": "mocha --config .mocharc.yml tests/dashboard.test.js",
    "test:ecg": "mocha --config .mocharc.yml tests/ecg.test.js",
    "test:twin": "mocha --config .mocharc.yml tests/digitalTwin.test.js",
    "test:medications": "mocha --config .mocharc.yml tests/medications.test.js",
    "test:history": "mocha --config .mocharc.yml tests/history.test.js",
    "test:doctors": "mocha --config .mocharc.yml tests/doctors.test.js",
    "test:profile": "mocha --config .mocharc.yml tests/profile.test.js",
    "test:settings": "mocha --config .mocharc.yml tests/settings.test.js",
    "test:validation": "mocha --config .mocharc.yml tests/validation.test.js",
    "report:merge": "mochawesome-merge reports/mochawesome-report/*.json > reports/merged-report.json",
    "report:generate": "marge reports/merged-report.json --reportDir reports --reportFilename selenium-e2e-report --inline"
  },
  "dependencies": {
    "selenium-webdriver": "^4.27.0",
    "chromedriver": "^131.0.0",
    "geckodriver": "^4.5.1",
    "mocha": "^11.1.0",
    "chai": "^4.5.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "exceljs": "^4.4.0",
    "winston": "^3.17.0",
    "cross-env": "^7.0.3"
  },
  "keywords": ["selenium", "e2e", "testing", "cardiotwin", "automation"],
  "author": "CardioTwin QA Team",
  "license": "ISC"
}
